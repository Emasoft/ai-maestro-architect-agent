#!/usr/bin/env python3
# pre-push hook - Validate plugin before allowing push
#
# Runs validate_plugin.py in strict mode: ALL severity levels
# (CRITICAL, MAJOR, MINOR) block the push.
#
# Exit codes from validate_plugin.py:
#   0 - All checks passed
#   1 - CRITICAL issues found (blocks push)
#   2 - MAJOR issues found (blocks push)
#   3 - MINOR issues found (blocks push)
#
# To install:
#   mkdir -p .git/hooks && cp scripts/git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# To bypass (NOT RECOMMENDED):
#   git push --no-verify

import fnmatch
import shutil
import subprocess
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Color support: disabled when not writing to a TTY (CI, Windows cmd, pipes)
# ---------------------------------------------------------------------------
if sys.stdout.isatty():
    RED = "\033[0;31m"
    YELLOW = "\033[1;33m"
    GREEN = "\033[0;32m"
    BLUE = "\033[0;34m"
    NC = "\033[0m"
else:
    RED = ""
    YELLOW = ""
    GREEN = ""
    BLUE = ""
    NC = ""


def cprint(color: str, text: str) -> None:
    """Print text wrapped in an ANSI color code (no-op when colors are off)."""
    print(f"{color}{text}{NC}")


# ---------------------------------------------------------------------------
# Helpers for git commands
# ---------------------------------------------------------------------------

def git(*args: str, capture: bool = True) -> subprocess.CompletedProcess:
    """Run a git command and return the CompletedProcess result."""
    return subprocess.run(
        ["git", *args],
        capture_output=capture,
        text=True,
    )


def git_output(*args: str, default: str = "") -> str:
    """Return stdout of a git command, or *default* on failure."""
    result = git(*args)
    if result.returncode != 0:
        return default
    return result.stdout.strip()


# ---------------------------------------------------------------------------
# Plugin-file pattern check
# ---------------------------------------------------------------------------

# Glob patterns that indicate a plugin-relevant file changed
_PLUGIN_PATTERNS = [
    ".claude-plugin/*",
    "agents/*",
    "commands/*",
    "skills/*",
    "hooks/*",
    "scripts/*.py",
    "scripts/*.sh",
    "*.mcp.json",
]


def is_plugin_file(path: str) -> bool:
    """Return True when *path* matches any plugin-file glob pattern."""
    for pattern in _PLUGIN_PATTERNS:
        if fnmatch.fnmatch(path, pattern):
            return True
    return False


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    # Get repo root
    repo_root_str = git_output("rev-parse", "--show-toplevel")
    if not repo_root_str:
        cprint(RED, "ERROR: Could not determine git repository root.")
        sys.exit(1)
    repo_root = Path(repo_root_str)

    # Banner
    cprint(BLUE, "========================================")
    cprint(BLUE, "  Pre-push Plugin Validation")
    cprint(BLUE, "========================================")
    print()

    # Remote info comes from argv (git passes remote name and URL as args 1 & 2)
    remote = sys.argv[1] if len(sys.argv) > 1 else "(unknown)"
    url = sys.argv[2] if len(sys.argv) > 2 else "(unknown)"
    print(f"{BLUE}Pushing to:{NC} {remote} ({url})")
    print()

    # -----------------------------------------------------------------
    # Read push refs from stdin.
    # Git writes one line per ref: <local-ref> <local-sha> <remote-ref> <remote-sha>
    # -----------------------------------------------------------------
    plugin_files_changed = False

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue

        parts = line.split()
        if len(parts) < 4:
            continue

        _local_ref, local_sha, _remote_ref, remote_sha = parts[:4]

        NULL_SHA = "0000000000000000000000000000000000000000"

        if local_sha == NULL_SHA:
            # Branch deletion — no validation needed
            cprint(GREEN, "Branch deletion detected. No validation needed.")
            continue

        if remote_sha == NULL_SHA:
            # New branch — check all files reachable from the tip
            result = git("diff", "--name-only", local_sha, "HEAD~10")
            if result.returncode != 0:
                # Fall back: list every tracked file in the commit tree
                result = git("ls-tree", "-r", "--name-only", local_sha)
            changed_files = result.stdout.strip().splitlines()
        else:
            # Existing branch — check only the files that differ
            result = git("diff", "--name-only", f"{remote_sha}..{local_sha}")
            changed_files = result.stdout.strip().splitlines() if result.returncode == 0 else []

        for f in changed_files:
            if is_plugin_file(f):
                plugin_files_changed = True
                break

        if plugin_files_changed:
            break

    if not plugin_files_changed:
        cprint(GREEN, "No plugin files changed. Skipping validation.")
        sys.exit(0)

    # -----------------------------------------------------------------
    # Run validation
    # -----------------------------------------------------------------
    cprint(BLUE, "Running plugin validation...")
    print()

    # Change to repo root so relative paths in scripts work correctly
    import os
    os.chdir(repo_root)

    # Optionally sync validation scripts from CPV repo (requires gh CLI + network)
    if shutil.which("gh"):
        cprint(BLUE, "Syncing validation scripts from CPV repo...")
        sync_script = repo_root / "scripts" / "sync_cpv_scripts.py"
        sync_result = subprocess.run(
            [sys.executable, str(sync_script)],
            capture_output=True,
            text=True,
        )
        if sync_result.returncode == 0:
            cprint(GREEN, "Validation scripts synced.")
        else:
            cprint(YELLOW, "Could not sync validation scripts (offline?). Using local copies.")

    # Ensure validate_plugin.py exists
    validator = repo_root / "scripts" / "validate_plugin.py"
    if not validator.is_file():
        cprint(RED, "ERROR: scripts/validate_plugin.py not found")
        cprint(RED, "Cannot validate plugin. Push blocked.")
        sys.exit(1)

    # Choose runner: prefer uv (handles dependencies), fall back to python3 / python
    if shutil.which("uv"):
        cmd = ["uv", "run", "--with", "pyyaml", "python", str(validator), ".", "--verbose"]
    elif shutil.which("python3"):
        cmd = ["python3", str(validator), ".", "--verbose"]
    else:
        cmd = ["python", str(validator), ".", "--verbose"]

    validation_result = subprocess.run(cmd)
    exit_code = validation_result.returncode

    print()

    # -----------------------------------------------------------------
    # Interpret exit codes — ALL non-zero codes block the push
    # -----------------------------------------------------------------
    if exit_code == 0:
        cprint(GREEN, "========================================")
        cprint(GREEN, "  PASSED: All validation checks passed")
        cprint(GREEN, "  Push allowed.")
        cprint(GREEN, "========================================")
        sys.exit(0)
    elif exit_code == 1:
        cprint(RED, "========================================")
        cprint(RED, "  BLOCKED: CRITICAL issues found")
        cprint(RED, "  Fix ALL issues before pushing.")
        cprint(RED, "========================================")
        sys.exit(1)
    elif exit_code == 2:
        cprint(RED, "========================================")
        cprint(RED, "  BLOCKED: MAJOR issues found")
        cprint(RED, "  Fix ALL issues before pushing.")
        cprint(RED, "========================================")
        sys.exit(1)
    elif exit_code == 3:
        cprint(YELLOW, "========================================")
        cprint(YELLOW, "  BLOCKED: MINOR issues found")
        cprint(YELLOW, "  Fix ALL issues before pushing.")
        cprint(YELLOW, "========================================")
        sys.exit(1)
    else:
        cprint(RED, "========================================")
        cprint(RED, f"  ERROR: Validation failed (exit {exit_code})")
        cprint(RED, "  Please check the validation script.")
        cprint(RED, "========================================")
        sys.exit(1)


if __name__ == "__main__":
    main()
